from PySide6.QtWidgets import (QDialog, QVBoxLayout, QHBoxLayout, QPushButton, 
                              QListWidget, QLabel, QInputDialog, QMessageBox,
                              QComboBox, QGroupBox, QTreeWidget, QTreeWidgetItem, QMenu)
from PySide6.QtCore import Qt, Signal
import json
import os
from ui.vol2_area import CollapsibleButtonGroup as Vol2CollapsibleButtonGroup
from ui.vol3_area import CollapsibleButtonGroup as Vol3CollapsibleButtonGroup
from ui.memprocfs_area import CollapsibleButtonGroup as MemProcFSCollapsibleButtonGroup

class TaskSchedulerDialog(QDialog):
    task_execute = Signal(list)  # 发送任务列表信号
    DEFAULT_FLOW_FILE = 'config/task_flows/default_flow.json'  # 添加默认配置文件路径

    def __init__(self, parent=None):
        super().__init__(parent)
        self.setWindowTitle("任务编排")
        self.resize(1000, 700)
        self.parent = parent
        self.setup_ui()
        
        self.load_default_flow()  # 先加载默认配置
        self.load_tasks()
        self.update_available_tasks()
        
        # 如果加载后没有任何阶段，则创建一个初始阶段
        if self.stage_tree.topLevelItemCount() == 0:
            self.add_stage()

    def setup_ui(self):
        layout = QVBoxLayout(self)

        # 创建上半部分的布局（任务选择区域）
        upper_layout = QHBoxLayout()

        # 左侧可用任务列表
        tasks_group = QGroupBox("可用任务")
        tasks_layout = QVBoxLayout(tasks_group)
        
        # 添加区域选择下拉框
        self.area_combo = QComboBox()
        self.area_combo.addItems(["MemProcFS", "Volatility 2", "Volatility 3"])
        self.area_combo.currentTextChanged.connect(self.update_available_tasks)
        tasks_layout.addWidget(self.area_combo)
        
        self.available_tasks = QTreeWidget()
        self.available_tasks.setHeaderLabels(["功能组"])
        self.available_tasks.setColumnWidth(0, 150)
        self.available_tasks.itemDoubleClicked.connect(self.on_task_double_clicked)  # 添加这行
        tasks_layout.addWidget(self.available_tasks)
        
        # 添加任务按钮
        add_button = QPushButton("添加到选中阶段 →")
        add_button.clicked.connect(self.add_task)
        tasks_layout.addWidget(add_button)
        
        upper_layout.addWidget(tasks_group)

        # 右侧任务阶段列表
        selected_group = QGroupBox("任务阶段")
        selected_layout = QVBoxLayout(selected_group)
        
        # 阶段操作按钮
        stage_button_layout = QHBoxLayout()
        add_stage_button = QPushButton("添加阶段")
        add_stage_button.clicked.connect(self.add_stage)
        remove_stage_button = QPushButton("删除阶段")
        remove_stage_button.clicked.connect(self.remove_stage)
        stage_button_layout.addWidget(add_stage_button)
        stage_button_layout.addWidget(remove_stage_button)
        selected_layout.addLayout(stage_button_layout)
        
        # 阶段树形视图
        self.stage_tree = QTreeWidget()
        self.stage_tree.setHeaderLabels(["阶段/任务"])
        self.stage_tree.setContextMenuPolicy(Qt.CustomContextMenu)
        self.stage_tree.customContextMenuRequested.connect(self.show_stage_context_menu)
        selected_layout.addWidget(self.stage_tree)
        
        # 任务操作按钮
        task_button_layout = QHBoxLayout()
        remove_task_button = QPushButton("删除任务")
        remove_task_button.clicked.connect(self.remove_task)
        move_up_button = QPushButton("上移")
        move_up_button.clicked.connect(self.move_task_up)
        move_down_button = QPushButton("下移")
        move_down_button.clicked.connect(self.move_task_down)
        
        task_button_layout.addWidget(remove_task_button)
        task_button_layout.addWidget(move_up_button)
        task_button_layout.addWidget(move_down_button)
        selected_layout.addLayout(task_button_layout)
        
        upper_layout.addWidget(selected_group)
        layout.addLayout(upper_layout)

        # 底部按钮
        bottom_layout = QHBoxLayout()
        save_button = QPushButton("保存任务流程")
        save_button.clicked.connect(self.save_task_flow)
        load_button = QPushButton("加载任务流程")
        load_button.clicked.connect(self.load_task_flow)
        execute_button = QPushButton("执行")
        execute_button.clicked.connect(self.execute_tasks)
        
        bottom_layout.addWidget(save_button)
        bottom_layout.addWidget(load_button)
        bottom_layout.addWidget(execute_button)
        layout.addLayout(bottom_layout)

    def get_memprocfs_tasks(self):
        memprocfs_area = self.parent.main_window.memprocfs_area
        tasks = {}
        # 遍历所有 CollapsibleButtonGroup
        for group in memprocfs_area.findChildren(MemProcFSCollapsibleButtonGroup):
            group_name = group.title
            group_buttons = []
            # 遍历组内的所有按钮
            for i in range(group.content_layout.count()):
                widget = group.content_layout.itemAt(i).widget()
                if isinstance(widget, QPushButton):
                    group_buttons.append(widget.text())
            if group_buttons:  # 只添加非空的组
                tasks[group_name] = group_buttons
        return tasks

    def get_vol2_tasks(self):
        vol2_area = self.parent.main_window.vol2_area
        tasks = {}
        # 遍历所有 CollapsibleButtonGroup
        for group in vol2_area.findChildren(Vol2CollapsibleButtonGroup):
            group_name = group.title
            group_buttons = []
            # 遍历组内的所有按钮
            for i in range(group.content_layout.count()):
                widget = group.content_layout.itemAt(i).widget()
                if isinstance(widget, QPushButton):
                    # 获取按钮文本，包括括号中的内容
                    group_buttons.append(widget.text())
            if group_buttons:  # 只添加非空的组
                tasks[group_name] = group_buttons
        return tasks

    def get_vol3_tasks(self):
        vol3_area = self.parent.main_window.vol3_area
        tasks = {}
        # 遍历所有 CollapsibleButtonGroup
        for group in vol3_area.findChildren(Vol3CollapsibleButtonGroup):
            group_name = group.title
            group_buttons = []
            # 遍历组内的所有按钮
            for button in group.buttons:
                if isinstance(button, QPushButton):
                    # 获取按钮文本，包括括号中的内容
                    group_buttons.append(button.text())
            if group_buttons:  # 只添加非空的组
                tasks[group_name] = group_buttons
        return tasks

    def update_available_tasks(self):
        try:
            self.available_tasks.clear()
            area = self.area_combo.currentText()
            
            if area == "MemProcFS":
                tasks = self.get_memprocfs_tasks()
            elif area == "Volatility 2":
                tasks = self.get_vol2_tasks()
            elif area == "Volatility 3":
                tasks = self.get_vol3_tasks()
            elif area == "快速检查":
                tasks = {"其他功能": ["常备知识", "强制重置VOL3缓存", "任务编排"]}
            
            # # 添加调试输出
            # print(f"Area: {area}")
            # print(f"Tasks: {tasks}")
            
            for group_name, task_list in tasks.items():
                group_item = QTreeWidgetItem([group_name])
                for task in task_list:
                    if task:  # 确保任务名不为空
                        task_item = QTreeWidgetItem([task])
                        group_item.addChild(task_item)
                if group_item.childCount() > 0:  # 只添加非空的组
                    self.available_tasks.addTopLevelItem(group_item)
                    group_item.setExpanded(True)
        except Exception as e:
            print(f"Error updating available tasks: {str(e)}")
            import traceback
            traceback.print_exc()

    def add_stage(self):
        stage_count = self.stage_tree.topLevelItemCount()
        stage_item = QTreeWidgetItem([f"阶段 {stage_count + 1}"])
        self.stage_tree.addTopLevelItem(stage_item)
        stage_item.setExpanded(True)
        self.save_to_default_flow()

    def remove_stage(self):
        current_item = self.stage_tree.currentItem()
        if current_item and current_item.parent() is None:
            self.stage_tree.takeTopLevelItem(self.stage_tree.indexOfTopLevelItem(current_item))
            self.save_to_default_flow()

    def add_task(self):
        current_task = self.available_tasks.currentItem()
        if not current_task:
            return
            
        # 如果选中的是组，不添加
        if current_task.parent() is None:
            return
            
        current_stage = self.stage_tree.currentItem()
        if not current_stage:
            QMessageBox.warning(self, "警告", "请先选择要添加到哪个阶段！")
            return
            
        # 如果选中的是任务，获取其父级阶段
        if current_stage.parent():
            current_stage = current_stage.parent()
            
        area = self.area_combo.currentText()
        task_text = f"{area} - {current_task.text(0)}"
        task_item = QTreeWidgetItem([task_text])
        current_stage.addChild(task_item)
        
        # 添加任务后自动保存
        self.save_to_default_flow()

    def remove_task(self):
        current_item = self.stage_tree.currentItem()
        if current_item and current_item.parent():
            current_item.parent().removeChild(current_item)
            self.save_to_default_flow()

    def move_task_up(self):
        current_item = self.stage_tree.currentItem()
        if not current_item or not current_item.parent():
            return
            
        parent = current_item.parent()
        index = parent.indexOfChild(current_item)
        if index > 0:
            parent.takeChild(index)
            parent.insertChild(index - 1, current_item)
            self.stage_tree.setCurrentItem(current_item)
            self.save_to_default_flow()

    def move_task_down(self):
        current_item = self.stage_tree.currentItem()
        if not current_item or not current_item.parent():
            return
            
        parent = current_item.parent()
        index = parent.indexOfChild(current_item)
        if index < parent.childCount() - 1:
            parent.takeChild(index)
            parent.insertChild(index + 1, current_item)
            self.stage_tree.setCurrentItem(current_item)
            self.save_to_default_flow()

    def save_task_flow(self):
        name, ok = QInputDialog.getText(self, "保存任务流程", "请输入任务流程名称:")
        if ok and name:
            stages = []
            for i in range(self.stage_tree.topLevelItemCount()):
                stage = self.stage_tree.topLevelItem(i)
                stage_tasks = []
                for j in range(stage.childCount()):
                    task = stage.child(j)
                    stage_tasks.append(task.text(0))
                stages.append({
                    "name": stage.text(0),
                    "tasks": stage_tasks
                })
            
            flow_data = {
                "name": name,
                "stages": stages
            }
            
            os.makedirs('config/task_flows', exist_ok=True)
            with open(f'config/task_flows/{name}.json', 'w', encoding='utf-8') as f:
                json.dump(flow_data, f, ensure_ascii=False, indent=2)
            QMessageBox.information(self, "成功", "任务流程保存成功！")

    def load_task_flow(self):
        flows_dir = 'config/task_flows'
        if not os.path.exists(flows_dir):
            QMessageBox.warning(self, "错误", "没有找到已保存的任务流程！")
            return

        flows = [f[:-5] for f in os.listdir(flows_dir) if f.endswith('.json')]
        if not flows:
            QMessageBox.warning(self, "错误", "没有找到已保存的任务流程！")
            return

        name, ok = QInputDialog.getItem(self, "加载任务流程", 
                                      "选择要加载的任务流程:", flows, 0, False)
        if ok and name:
            try:
                with open(f'config/task_flows/{name}.json', 'r', encoding='utf-8') as f:
                    flow_data = json.load(f)
                
                self.stage_tree.clear()
                for stage in flow_data["stages"]:
                    stage_item = QTreeWidgetItem([stage["name"]])
                    for task in stage["tasks"]:
                        task_item = QTreeWidgetItem([task])
                        stage_item.addChild(task_item)
                    self.stage_tree.addTopLevelItem(stage_item)
                    stage_item.setExpanded(True)
                    
            except Exception as e:
                QMessageBox.warning(self, "错误", f"加载任务流程失败：{str(e)}")

    def execute_tasks(self):
        all_tasks = []
        for i in range(self.stage_tree.topLevelItemCount()):
            stage = self.stage_tree.topLevelItem(i)
            stage_tasks = []
            for j in range(stage.childCount()):
                task = stage.child(j)
                stage_tasks.append(task.text(0))
            all_tasks.append({
                "stage": stage.text(0),
                "tasks": stage_tasks
            })
        
        if not all_tasks:
            QMessageBox.warning(self, "警告", "请先添加要执行的任务！")
            return
        
        reply = QMessageBox.question(self, "确认", 
                                   "是否确定要执行选定的任务流程？\n这些任务将按阶段顺序执行。",
                                   QMessageBox.Yes | QMessageBox.No)
        if reply == QMessageBox.Yes:
            self.task_execute.emit(all_tasks)
            self.hide()  # 改为隐藏而不是关闭

    def load_tasks(self):
        # 这里可以从配置文件加载之前保存的任务列表
        pass

    def on_task_double_clicked(self, item, column):
        """处理任务双击事件"""
        if not item or not item.parent():  # 如果是组标题，不处理
            return
            
        # 获取当前选中的阶段，如果没有选中任何阶段，使用最后一个阶段
        current_stage = self.stage_tree.currentItem()
        if not current_stage:
            # 如果没有选中的阶段，使用最后一个阶段
            last_index = self.stage_tree.topLevelItemCount() - 1
            if last_index >= 0:
                current_stage = self.stage_tree.topLevelItem(last_index)
            else:
                # 如果没有阶段，创建一个新阶段
                self.add_stage()
                current_stage = self.stage_tree.topLevelItem(0)
        elif current_stage.parent():  # 如果选中的是任务，获取其父级阶段
            current_stage = current_stage.parent()
            
        # 添加任务到阶段
        area = self.area_combo.currentText()
        task_text = f"{area} - {item.text(0)}"
        task_item = QTreeWidgetItem([task_text])
        current_stage.addChild(task_item)
        
        # 保存到默认配置文件
        self.save_to_default_flow()

    def save_to_default_flow(self):
        """保存当前配置到默认配置文件"""
        try:
            stages = []
            for i in range(self.stage_tree.topLevelItemCount()):
                stage = self.stage_tree.topLevelItem(i)
                stage_tasks = []
                for j in range(stage.childCount()):
                    task = stage.child(j)
                    stage_tasks.append(task.text(0))
                stages.append({
                    "name": stage.text(0),
                    "tasks": stage_tasks
                })
            
            flow_data = {
                "name": "default",
                "stages": stages
            }
            
            os.makedirs(os.path.dirname(self.DEFAULT_FLOW_FILE), exist_ok=True)
            with open(self.DEFAULT_FLOW_FILE, 'w', encoding='utf-8') as f:
                json.dump(flow_data, f, ensure_ascii=False, indent=2)
                
            print(f"Successfully saved default flow to {self.DEFAULT_FLOW_FILE}")  # 添加调试输出
        except Exception as e:
            print(f"Error saving default flow: {str(e)}")
            import traceback
            traceback.print_exc()

    def load_default_flow(self):
        """加载默认配置文件"""
        try:
            if os.path.exists(self.DEFAULT_FLOW_FILE):
                print(f"Loading default flow from {self.DEFAULT_FLOW_FILE}")  # 添加调试输出
                with open(self.DEFAULT_FLOW_FILE, 'r', encoding='utf-8') as f:
                    flow_data = json.load(f)
                
                self.stage_tree.clear()
                for stage in flow_data["stages"]:
                    stage_item = QTreeWidgetItem([stage["name"]])
                    for task in stage["tasks"]:
                        task_item = QTreeWidgetItem([task])
                        stage_item.addChild(task_item)
                    self.stage_tree.addTopLevelItem(stage_item)
                    stage_item.setExpanded(True)
                print("Successfully loaded default flow")  # 添加调试输出
            else:
                print(f"Default flow file not found: {self.DEFAULT_FLOW_FILE}")  # 添加调试输出
        except Exception as e:
            print(f"Error loading default flow: {str(e)}")
            import traceback
            traceback.print_exc()

    def show_stage_context_menu(self, position):
        """显示阶段的右键菜单"""
        item = self.stage_tree.itemAt(position)
        if item and not item.parent():  # 确保右键点击的是阶段而不是任务
            menu = QMenu()
            execute_action = menu.addAction("执行此阶段")
            action = menu.exec_(self.stage_tree.viewport().mapToGlobal(position))
            
            if action == execute_action:
                self.execute_single_stage(item)

    def execute_single_stage(self, stage_item):
        """执行单个阶段"""
        stage_tasks = []
        for j in range(stage_item.childCount()):
            task = stage_item.child(j)
            stage_tasks.append(task.text(0))
        
        if not stage_tasks:
            QMessageBox.warning(self, "警告", "该阶段没有任务！")
            return
        
        stage_data = {
            "stage": stage_item.text(0),
            "tasks": stage_tasks
        }
        
        reply = QMessageBox.question(self, "确认", 
                                   f"是否确定要执行 {stage_item.text(0)}？\n这将执行该阶段的所有任务。",
                                   QMessageBox.Yes | QMessageBox.No)
        if reply == QMessageBox.Yes:
            self.task_execute.emit([stage_data])  # 发送单个阶段的数据
            self.hide()