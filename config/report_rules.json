[
  {
    "name": "用户SID",
    "file_pattern": "M:/sys/sysinfo/sysinfo.txt",
    "regex_pattern": "S-1-5-21-\\d+-\\d+-\\d+-\\d+",
    "template_text": "用户SID：\n{match}"
  },
  {
    "name": "DHCPIP",
    "file_pattern": "M:/sys/sysinfo/sysinfo.txt",
    "regex_pattern": "DhcpIPAddress:\\s*(.+)",
    "template_text": "DHCP获取的IP地址:{match1}"
  },
  {
    "name": "系统版本",
    "file_pattern": "M:/sys/version.txt",
    "regex_pattern": ".*",
    "template_text": "系统版本:{match}"
  }
]